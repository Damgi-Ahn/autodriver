<launch>
  <!-- ══════════════════════════════════════════════════════════════════════
       autodriver.launch.xml — Full system bringup

       Composes two sub-launches:
         perception.launch.xml  — GPU inference + camera capture pipeline
         monitoring.launch.xml  — GPU watchdog + metrics + profiler

       Topic map:
         camera_manager  ──DMABUF FD/IPC──►  tensorrt_inference_manager
         tensorrt_inference_manager  ──►  /perception/{model}/results
         gpu_watchdog               ──►  /system/watchdog/{status,alert}
         metrics_manager            ──►  /system/metrics
         pipeline_profiler          ──►  /system/profiler

       Usage:
         ros2 launch autodriver_bringup autodriver.launch.xml
         ros2 launch autodriver_bringup autodriver.launch.xml \
             debug_stream:=true
         ros2 launch autodriver_bringup autodriver.launch.xml \
             watchdog_throttle_temp_c:=80.0 \
             profiler_rate_hz:=2.0
       ══════════════════════════════════════════════════════════════════════ -->

  <!-- ── Perception config ─────────────────────────────────────────────── -->
  <arg name="cameras_yaml"
       default="$(find-pkg-share camera_manager)/config/cameras.yaml"/>
  <arg name="models_yaml"
       default="$(find-pkg-share tensorrt_inference_manager)/config/models.yaml"/>
  <arg name="system_yaml"
       default="$(find-pkg-share autodriver_bringup)/config/system.yaml"/>
  <arg name="ipc_socket_path"
       default="/tmp/autodriver/frames.sock"/>
  <arg name="debug_stream"
       default="false"
       description="Enable NVJPEG CompressedImage debug stream per camera"/>

  <!-- ── Monitoring overrides (default = system.yaml values) ───────────── -->
  <arg name="watchdog_poll_rate_hz"      default="2.0"/>
  <arg name="watchdog_stall_threshold_s" default="5.0"/>
  <arg name="watchdog_mem_warn_pct"      default="90.0"/>
  <arg name="watchdog_throttle_temp_c"   default="85.0"/>
  <arg name="metrics_rate_hz"            default="1.0"/>
  <arg name="metrics_model_names"        default="['yolo', 'lane', 'segmentation']"/>
  <arg name="profiler_rate_hz"           default="1.0"/>

  <!-- ══════════════════════════════════════════════════════════════════════
       Perception pipeline
       (tensorrt_inference_manager + camera_manager)
       ══════════════════════════════════════════════════════════════════════ -->
  <include file="$(find-pkg-share autodriver_bringup)/launch/perception.launch.xml">
    <arg name="cameras_yaml"    value="$(var cameras_yaml)"/>
    <arg name="models_yaml"     value="$(var models_yaml)"/>
    <arg name="system_yaml"     value="$(var system_yaml)"/>
    <arg name="ipc_socket_path" value="$(var ipc_socket_path)"/>
    <arg name="debug_stream"    value="$(var debug_stream)"/>
  </include>

  <!-- ══════════════════════════════════════════════════════════════════════
       Monitoring stack
       (gpu_watchdog + metrics_manager + pipeline_profiler)
       ══════════════════════════════════════════════════════════════════════ -->
  <include file="$(find-pkg-share autodriver_bringup)/launch/monitoring.launch.xml">
    <arg name="watchdog_poll_rate_hz"      value="$(var watchdog_poll_rate_hz)"/>
    <arg name="watchdog_stall_threshold_s" value="$(var watchdog_stall_threshold_s)"/>
    <arg name="watchdog_mem_warn_pct"      value="$(var watchdog_mem_warn_pct)"/>
    <arg name="watchdog_throttle_temp_c"   value="$(var watchdog_throttle_temp_c)"/>
    <arg name="metrics_rate_hz"            value="$(var metrics_rate_hz)"/>
    <arg name="metrics_stall_threshold_s"  value="$(var watchdog_stall_threshold_s)"/>
    <arg name="metrics_model_names"        value="$(var metrics_model_names)"/>
    <arg name="profiler_rate_hz"           value="$(var profiler_rate_hz)"/>
  </include>

</launch>
