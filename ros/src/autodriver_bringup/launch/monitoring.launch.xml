<launch>
  <!-- ══════════════════════════════════════════════════════════════════════
       monitoring.launch.xml
       Launches the system health and observability stack:
         1. gpu_watchdog       — Thermal + memory + GPU stall detection
         2. metrics_manager    — Pipeline metrics aggregation (1 Hz)
         3. pipeline_profiler  — End-to-end stage latency profiling

       Published topics:
         /system/watchdog/status  (DiagnosticArray) — GPU health per poll
         /system/watchdog/alert   (String)          — Level-change alerts
         /system/metrics          (DiagnosticArray) — Aggregated pipeline metrics
         /system/profiler         (Float32MultiArray)— Stage latency stats

       All three nodes use respawn=true so a crash does not bring down
       the perception pipeline.

       Standalone usage:
         ros2 launch autodriver_bringup monitoring.launch.xml
         ros2 launch autodriver_bringup monitoring.launch.xml \
             watchdog_poll_rate_hz:=4.0 \
             profiler_rate_hz:=2.0
       ══════════════════════════════════════════════════════════════════════ -->

  <!-- ── GPU watchdog thresholds ───────────────────────────────────────── -->
  <arg name="watchdog_poll_rate_hz"
       default="2.0"
       description="GPU health poll frequency (Hz). Mirror of system.yaml[watchdog.poll_rate_hz]"/>
  <arg name="watchdog_stall_threshold_s"
       default="5.0"
       description="Seconds of zero GPU load before ERROR alert"/>
  <arg name="watchdog_mem_warn_pct"
       default="90.0"
       description="CUDA memory usage % threshold for WARN alert"/>
  <arg name="watchdog_throttle_temp_c"
       default="85.0"
       description="GPU temperature (°C) threshold for WARN alert"/>

  <!-- ── Metrics manager config ────────────────────────────────────────── -->
  <arg name="metrics_rate_hz"
       default="1.0"
       description="DiagnosticArray publish rate for /system/metrics"/>
  <arg name="metrics_stall_threshold_s"
       default="5.0"
       description="Topic stall detection threshold (s) — should match watchdog"/>
  <arg name="metrics_model_names"
       default="['yolo', 'lane', 'segmentation']"
       description="Model names to subscribe to on /perception/{name}/results"/>

  <!-- ── Pipeline profiler config ──────────────────────────────────────── -->
  <arg name="profiler_rate_hz"
       default="1.0"
       description="Stats publish rate for /system/profiler (Hz)"/>

  <!-- ── 1. GPU watchdog ────────────────────────────────────────────────── -->
  <include file="$(find-pkg-share gpu_watchdog)/launch/gpu_watchdog.launch.xml">
    <arg name="poll_rate_hz"      value="$(var watchdog_poll_rate_hz)"/>
    <arg name="stall_threshold_s" value="$(var watchdog_stall_threshold_s)"/>
    <arg name="mem_warn_pct"      value="$(var watchdog_mem_warn_pct)"/>
    <arg name="throttle_temp_c"   value="$(var watchdog_throttle_temp_c)"/>
  </include>

  <!-- ── 2. Metrics manager ────────────────────────────────────────────── -->
  <include file="$(find-pkg-share metrics_manager)/launch/metrics_manager.launch.xml">
    <arg name="publish_rate_hz"   value="$(var metrics_rate_hz)"/>
    <arg name="stall_threshold_s" value="$(var metrics_stall_threshold_s)"/>
    <arg name="model_names"       value="$(var metrics_model_names)"/>
  </include>

  <!-- ── 3. Pipeline profiler ──────────────────────────────────────────── -->
  <include
    file="$(find-pkg-share pipeline_profiler)/launch/pipeline_profiler.launch.xml">
    <arg name="publish_rate_hz" value="$(var profiler_rate_hz)"/>
  </include>

</launch>
