<launch>
  <!-- ─────────────────────────────────────────────────────────────────────── -->
  <!-- perception_system.launch.xml                                           -->
  <!-- Top-level launch for the autodriver perception pipeline.               -->
  <!--                                                                        -->
  <!-- Node startup order (IPC socket dependency):                            -->
  <!--   1. tensorrt_inference_manager  — binds IPC server socket             -->
  <!--   2. camera_manager             — connects to IPC server               -->
  <!--   3. metrics_manager, pipeline_profiler, gpu_watchdog                  -->
  <!-- ─────────────────────────────────────────────────────────────────────── -->

  <!-- ── Config path arguments ──────────────────────────────────────────── -->
  <arg name="cameras_yaml"
       default="$(find-pkg-share camera_manager)/config/cameras.yaml"
       description="cameras.yaml path"/>
  <arg name="models_yaml"
       default="$(find-pkg-share tensorrt_inference_manager)/config/models.yaml"
       description="models.yaml path"/>
  <arg name="system_yaml"
       default="$(find-pkg-share autodriver_bringup)/config/system.yaml"
       description="Shared system parameters YAML"/>
  <arg name="ipc_socket_path"
       default="/tmp/autodriver/frames.sock"
       description="Unix domain socket path for DMABUF FD transport"/>
  <arg name="debug_stream"
       default="false"
       description="Enable per-camera NVJPEG debug stream"/>

  <!-- ── 1. Inference manager (must bind IPC socket before cameras start) ─ -->
  <include file="$(find-pkg-share tensorrt_inference_manager)/launch/inference_manager.launch.xml">
    <arg name="models_yaml"     value="$(var models_yaml)"/>
    <arg name="system_yaml"     value="$(var system_yaml)"/>
    <arg name="ipc_socket_path" value="$(var ipc_socket_path)"/>
  </include>

  <!-- ── 2. Camera manager (IPC client — connects after inference_manager) ─ -->
  <include file="$(find-pkg-share camera_manager)/launch/camera_manager.launch.xml">
    <arg name="cameras_yaml"    value="$(var cameras_yaml)"/>
    <arg name="ipc_socket_path" value="$(var ipc_socket_path)"/>
    <arg name="debug_stream"    value="$(var debug_stream)"/>
  </include>

  <!-- ── 3. System monitoring ────────────────────────────────────────────── -->
  <include file="$(find-pkg-share metrics_manager)/launch/metrics_manager.launch.xml"/>
  <include file="$(find-pkg-share pipeline_profiler)/launch/pipeline_profiler.launch.xml"/>
  <include file="$(find-pkg-share gpu_watchdog)/launch/gpu_watchdog.launch.xml"/>
</launch>
