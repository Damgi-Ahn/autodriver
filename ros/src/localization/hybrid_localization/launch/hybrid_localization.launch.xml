<launch>
  <arg name="params_yaml" default="$(find-pkg-share hybrid_localization)/config/hybrid_localization.param.yaml"/>
  <arg name="log_level" default="info"/>

  <node
    pkg="hybrid_localization"
    exec="hybrid_localization_node"
    name="hybrid_localization"
    output="screen"
    args="--ros-args --log-level $(var log_level)">
    <param from="$(var params_yaml)"/>
  </node>
</launch>
