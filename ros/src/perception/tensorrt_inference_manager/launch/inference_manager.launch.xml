<launch>
  <!-- ───────────────────────────────────────────────────────────────────── -->
  <!-- inference_manager.launch.xml                                         -->
  <!-- Launch tensorrt_inference_manager_node.                              -->
  <!-- Start this BEFORE camera_manager — the node binds the IPC socket     -->
  <!-- in its constructor and blocks until camera_manager connects.          -->
  <!-- ───────────────────────────────────────────────────────────────────── -->

  <arg name="models_yaml"
       default="$(find-pkg-share tensorrt_inference_manager)/config/models.yaml"
       description="TensorRT engine configuration YAML"/>
  <arg name="system_yaml"
       default="$(find-pkg-share autodriver_bringup)/config/system.yaml"
       description="Shared system parameters YAML"/>
  <arg name="ipc_socket_path"
       default="/tmp/autodriver/frames.sock"
       description="Unix domain socket path (must match camera_manager)"/>

  <node pkg="tensorrt_inference_manager"
        exec="tensorrt_inference_manager_node"
        name="tensorrt_inference_manager"
        output="screen">
    <param name="models_yaml"     value="$(var models_yaml)"/>
    <param name="system_yaml"     value="$(var system_yaml)"/>
    <param name="ipc_socket_path" value="$(var ipc_socket_path)"/>
  </node>
</launch>
