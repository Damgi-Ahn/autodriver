<launch>
  <!-- ───────────────────────────────────────────────────────────────── -->
  <!-- camera_manager.launch.xml                                         -->
  <!-- Launches the camera_manager_node with configurable YAML paths     -->
  <!-- and IPC socket address.                                           -->
  <!-- ───────────────────────────────────────────────────────────────── -->

  <arg name="cameras_yaml"
       default="$(find-pkg-share camera_manager)/config/cameras.yaml"
       description="Path to cameras.yaml configuration file"/>

  <arg name="ipc_socket_path"
       default="/tmp/autodriver/frames.sock"
       description="Unix domain socket path for DMABUF FD transport"/>

  <arg name="debug_stream"
       default="false"
       description="Enable NVJPEG compressed debug image stream"/>

  <node pkg="camera_manager"
        exec="camera_manager_node"
        name="camera_manager"
        output="screen">
    <param name="cameras_yaml"    value="$(var cameras_yaml)"/>
    <param name="ipc_socket_path" value="$(var ipc_socket_path)"/>
    <param name="debug_stream"    value="$(var debug_stream)"/>
  </node>
</launch>
