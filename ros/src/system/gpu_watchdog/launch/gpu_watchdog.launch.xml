<launch>
  <arg name="poll_rate_hz"      default="2.0"/>
  <arg name="stall_threshold_s" default="5.0"/>
  <arg name="mem_warn_pct"      default="90.0"/>
  <arg name="throttle_temp_c"   default="85.0"/>

  <node pkg="gpu_watchdog"
        exec="gpu_watchdog_node"
        name="gpu_watchdog"
        output="screen">
    <param name="poll_rate_hz"      value="$(var poll_rate_hz)"/>
    <param name="stall_threshold_s" value="$(var stall_threshold_s)"/>
    <param name="mem_warn_pct"      value="$(var mem_warn_pct)"/>
    <param name="throttle_temp_c"   value="$(var throttle_temp_c)"/>
  </node>
</launch>
